# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  
  config.vm.box = "generic/debian12"
  config.vm.synced_folder ".", "/vagrant", type: "virtualbox"

  config.vm.define "lle-saulS" do |server|
    server.vm.hostname = "lle-saulS"
    server.vm.network "private_network", ip: "192.168.56.110"
    server.vm.provider "virtualbox" do |vb| 
      vb.memory = "1024"
      vb.cpus = 2
    end
    server.vm.provision "shell", run: "once", path: "./Server.sh"
  end

  config.vm.define "lle-saulSW" do |agent|
    agent.vm.hostname = "lle-saulSW"
    agent.vm.network "private_network", ip: "192.168.56.111"
    agent.vm.provider "virtualbox" do |vb| 
      vb.memory = "512" 
      vb.cpus = 1
    end
    agent.vm.provision "shell", run: "once", path: "./Agent.sh"
  end 

  
end
