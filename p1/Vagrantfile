Vagrant.configure(2) do |config|
  config.vm.box = "generic/debian12"
  config.vm.synced_folder ".", "/share"

  config.vm.define "aaudeberS" do |control|
    control.vm.hostname = "aaudeberS"

    control.vm.network :private_network, ip: "192.168.56.110"

    control.vm.provider :virtualbox do |v|
      v.name = "aaudeberS"
      v.gui = false
      v.memory = 2048
      v.cpus = 2
    end

    control.vm.provision "shell", path: "./scripts/install_master.sh"

  end

  config.vm.define "aaudeberSW" do |worker|
    worker.vm.hostname = "aaudeberSW"

    worker.vm.network :private_network, ip: "192.168.56.111"

    worker.vm.provider :virtualbox do |v|
      v.name = "aaudeberSW"
      v.gui = false
      v.memory = 1024
      v.cpus = 1
    end

    worker.vm.provision "shell", path: "./scripts/install_worker.sh"
  end
end
